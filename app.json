{
  "expo": {
    "name": "SBALT",
    "slug": "sbalt",
    "scheme": "sbalt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chihfan.sballt",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["sbalt", "exp"]
          }
        ],
        "NSPhotoLibraryUsageDescription": "SBALT 需要存取您的照片來設定頭像",
        "NSCalendarsFullAccessUsageDescription": "SBALT 需要存取行事曆來新增活動提醒",
        "NSLocationWhenInUseUsageDescription": "SBALT 需要定位來追蹤跑步路線",
        "LSApplicationQueriesSchemes": ["comgooglemaps"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.chihfan.sballt",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "SBALT 需要存取您的照片來設定頭像"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "SBALT 需要存取行事曆來新增活動提醒"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "SBALT 需要讀取您的運動紀錄（跑步、走路），用於建立個人戰績與排行榜。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supabaseUrl": "https://zavwiobxpuwgoqdmjmpg.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inphdndpb2J4cHV3Z29xZG1qbXBnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyNjQxNzUsImV4cCI6MjA5MTg0MDE3NX0.u7_7OnvuzNrBmIjZ0A9C79rQ0FdHb9M6Uh3fUMwo-kc",
      "oauthRedirectUrl": "sbalt://"
    }
  }
}
